{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <a href="{{ chat }}" class="btn btn-primary"><i class="fa-solid fa-robot"></i> {{ button_chat }}</a>
        <button type="submit" form="form-ai-builder" class="btn btn-primary"><i class="fa-solid fa-save"></i> {{ button_save }}</button>
        <a href="{{ back }}" class="btn btn-light"><i class="fa-solid fa-reply"></i> {{ button_back }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <div class="card">
      <div class="card-header"><i class="fa-solid fa-cog"></i> {{ text_edit }}</div>
      <div class="card-body">
        <form id="form-ai-builder" action="{{ save }}" method="post">
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="other_ai_builder_status" class="form-select">
                <option value="1"{% if other_ai_builder_status %} selected{% endif %}>{{ text_enabled }}</option>
                <option value="0"{% if not other_ai_builder_status %} selected{% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_api_key }}</label>
            <div class="col-sm-10">
              <input type="password" name="other_ai_builder_api_key" value="{{ other_ai_builder_api_key }}" class="form-control" placeholder="sk-..." autocomplete="off"/>
              <div class="form-text">Your OpenAI API key. Get one at <a href="https://platform.openai.com/api-keys" target="_blank">platform.openai.com</a></div>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_model }}</label>
            <div class="col-sm-10">
              <select name="other_ai_builder_model" class="form-select">
                <option value="gpt-4o-mini"{% if other_ai_builder_model == 'gpt-4o-mini' %} selected{% endif %}>GPT-4o Mini (Recommended)</option>
                <option value="gpt-4o"{% if other_ai_builder_model == 'gpt-4o' %} selected{% endif %}>GPT-4o</option>
                <option value="gpt-4-turbo"{% if other_ai_builder_model == 'gpt-4-turbo' %} selected{% endif %}>GPT-4 Turbo</option>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_temperature }}</label>
            <div class="col-sm-10">
              <input type="number" name="other_ai_builder_temperature" value="{{ other_ai_builder_temperature }}" class="form-control" min="0" max="1" step="0.1"/>
            </div>
          </div>
          <div class="row mb-3">
            <label class="col-sm-2 col-form-label">{{ entry_confirm }}</label>
            <div class="col-sm-10">
              <select name="other_ai_builder_confirm" class="form-select">
                <option value="1"{% if other_ai_builder_confirm %} selected{% endif %}>{{ text_enabled }}</option>
                <option value="0"{% if not other_ai_builder_confirm %} selected{% endif %}>{{ text_disabled }}</option>
              </select>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<script>
$('#form-ai-builder').on('submit', function(e) {
  e.preventDefault();
  $.ajax({
    url: $(this).attr('action'),
    type: 'POST',
    data: $(this).serialize(),
    dataType: 'json',
    success: function(json) {
      if (json.error) alert(json.error);
      if (json.success) alert(json.success);
    }
  });
});
</script>
{{ footer }}
