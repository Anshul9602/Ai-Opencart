{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button class="ai-btn-icon ai-header-btn" id="btn-theme" title="Toggle theme" type="button"><i class="fa-solid fa-moon"></i></button>
        <a href="{{ url_settings }}" class="btn btn-light"><i class="fa-solid fa-cog"></i> {{ text_settings }}</a>
      </div>
      <h1>{{ heading_title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    {% if not api_configured %}
    <div class="alert alert-warning">
      <i class="fa-solid fa-triangle-exclamation"></i>
      OpenAI API key not configured. <a href="{{ url_settings }}">Add your API key in Settings</a> to start using the AI assistant.
    </div>
    {% endif %}

    <div id="ai-app" class="ai-chat-embed" data-theme="light">
      <aside class="ai-sidebar" id="ai-sidebar">
        <div class="ai-sidebar-header">
          <button class="ai-btn-icon" id="btn-new-chat" title="New Chat" type="button"><i class="fa-solid fa-plus"></i></button>
          <span class="ai-logo"><i class="fa-solid fa-robot"></i> Chats</span>
          <button class="ai-btn-icon" id="btn-toggle-sidebar" title="Toggle sidebar" type="button"><i class="fa-solid fa-bars"></i></button>
        </div>
        <div class="ai-sidebar-search">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" placeholder="Search chats..." id="search-chats"/>
        </div>
        <div class="ai-chat-list" id="chat-list"></div>
      </aside>

      <main class="ai-main">
        <div class="ai-messages" id="messages">
          <div class="ai-welcome">
            <div class="ai-welcome-icon"><i class="fa-solid fa-robot"></i></div>
            <h2>Website Builder Assistant</h2>
            <p>Manage your entire OpenCart store through natural language. Try these commands:</p>
            <div class="ai-suggestions">
              <button class="ai-suggestion" type="button" data-msg="Change homepage banner">Change homepage banner</button>
              <button class="ai-suggestion" type="button" data-msg="Add new product">Add new product</button>
              <button class="ai-suggestion" type="button" data-msg="Show today's orders">Show today's orders</button>
              <button class="ai-suggestion" type="button" data-msg="Find customer">Find customer</button>
              <button class="ai-suggestion" type="button" data-msg="Create coupon">Create coupon</button>
              <button class="ai-suggestion" type="button" data-msg="Increase all prices by 5%">Bulk price update</button>
            </div>
          </div>
        </div>

        <div class="ai-input-area">
          <div class="ai-dropzone" id="dropzone">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Drop files here to upload</span>
          </div>
          <div class="ai-input-wrap">
            <button class="ai-btn-icon" id="btn-attach" title="Attach file" type="button"><i class="fa-solid fa-paperclip"></i></button>
            <input type="file" id="file-input" hidden accept="image/*,.csv,.xlsx,.xls,.pdf"/>
            <textarea id="message-input" placeholder="{{ text_placeholder }}" rows="1"></textarea>
            <button class="ai-btn-send" id="btn-send" title="Send" type="button"><i class="fa-solid fa-paper-plane"></i></button>
          </div>
          <div class="ai-input-hint">AI can make mistakes. Verify important changes. Supports images, CSV, Excel, PDF.</div>
        </div>
      </main>
    </div>
  </div>
</div>

<div class="ai-typing" id="typing-indicator" hidden>
  <div class="ai-typing-dots"><span></span><span></span><span></span></div>
  <span>{{ text_typing }}</span>
</div>

<script>
  window.AI_BUILDER = {
    user_token: '{{ user_token }}',
    session_id: 0,
    url_send: '{{ url_send }}',
    url_upload: '{{ url_upload }}',
    url_confirm: '{{ url_confirm }}',
    url_sessions: '{{ url_sessions }}',
    url_history: '{{ url_history }}',
    url_new_session: '{{ url_new_session }}',
    url_csv_template: '{{ url_csv_template }}',
    api_configured: {{ api_configured ? 'true' : 'false' }}
  };
</script>
<script src="../extension/ai_builder/admin/view/javascript/chat.js" type="text/javascript"></script>
{{ footer }}
